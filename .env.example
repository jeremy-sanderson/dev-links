# Domains to run the extension on (comma-separated Chrome match patterns)
DOMAINS=https://github.com/*

# Jira project prefixes to match (comma-separated, case-sensitive)
JIRA_PREFIXES=HTML,DAS,INFRA,VIDEO

# Base URL for Jira links (ticket ID is appended, e.g. ENG-1234)
JIRA_BASE_URL=https://mycompany.atlassian.net/browse/

# Re-scan interval in milliseconds
SCAN_INTERVAL=30000
